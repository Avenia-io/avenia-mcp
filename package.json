{
  "name": "@avenia-io/mcp-client",
  "version": "0.2.0",
  "description": "Official MCP server for the Avenia public API. Connect Claude Code, Cursor, Zed, and other MCP clients to the Avenia platform.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "avenia-mcp": "dist/index.js",
    "mcp-client": "dist/index.js"
  },
  "files": [
    "dist/**",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --target node20 --clean --dts && node -e \"const f=require('fs'),p='dist/index.js';f.writeFileSync(p,'#!/usr/bin/env node\\n'+f.readFileSync(p,'utf8'));f.chmodSync(p,0o755)\"",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "avenia",
    "mcp",
    "model-context-protocol",
    "payments",
    "fintech",
    "stablecoin",
    "pix",
    "claude",
    "cursor"
  ],
  "author": "Avenia",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Avenia-io/avenia-mcp.git"
  },
  "homepage": "https://api-reference.avenia.io",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.0",
    "undici": "^6.21.0",
    "zod": "^3.23.8"
  },
  "overrides": {
    "hono": "^4.12.18",
    "ip-address": "^10.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
